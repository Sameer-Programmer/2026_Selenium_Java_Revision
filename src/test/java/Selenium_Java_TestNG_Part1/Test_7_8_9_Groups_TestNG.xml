             <exclude name="Regression"></exclude>
         </run>
     </groups>
    <classes>
        <class name="Selenium_Java_TestNG_Part1.Test7_Groups_1" ></class>
        <class name="Selenium_Java_TestNG_Part1.Test8_Groups_2" ></class>
        <class name="Selenium_Java_TestNG_Part1.Test9_Groups_3" ></class>
    </classes>
 </test>
</suite>

